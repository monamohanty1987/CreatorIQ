# CreatorIQ Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# OPENAI API CONFIGURATION (REQUIRED for AI Features)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# Get your API key from: https://platform.openai.com/api-keys
# Note: You'll need an OpenAI account with API credits

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=sqlite:///./creatoriq.db

# ============================================
# API CONFIGURATION
# ============================================
API_TITLE=CreatorIQ API
API_DESCRIPTION=AI-Powered Content Intelligence Platform for Creators
API_VERSION=1.0.0

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# ============================================
# OPTIONAL: ANTHROPIC API (for Claude features)
# ============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# OPTIONAL: LANGSMITH TRACING (for debugging)
# ============================================
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=creatoriq-local

# ============================================
# OPTIONAL: N8N WORKFLOW ENGINE
# ============================================
N8N_HOST=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# ============================================
# RAG SERVICE CONFIGURATION
# ============================================
RAG_VECTOR_STORE_PATH=./vector_store
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# FRONTEND CONFIGURATION
# ============================================
REACT_APP_API_URL=http://localhost:5000
