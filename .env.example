# ============================================================
# CreatorIQ — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================

# ── ANTHROPIC / CLAUDE API ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPENAI API (used by n8n workflows O1, O3, O4) ──────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LANGSMITH TRACING ───────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=creatoriq-production
LANGCHAIN_ENDPOINT=https://eu.smith.langchain.com

# ── n8n CONFIGURATION ───────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_BRAND_DEAL=http://localhost:5678/webhook/brand-deal-check
N8N_WEBHOOK_CONTRACT=http://localhost:5678/webhook/analyse-contract
N8N_WEBHOOK_CAMPAIGN=http://localhost:5678/webhook/product-launch
N8N_TIMEOUT=30

# ── BACKEND SERVER ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
FRONTEND_URL=http://localhost:3000

# ── DATABASE ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./creatoriq.db
DATABASE_ECHO=false

# ── CLAUDE MODEL ────────────────────────────────────────────
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_TIMEOUT=60

# ── RAG / CHROMADB ──────────────────────────────────────────
# No extra config needed — ChromaDB runs in-memory locally
# Knowledge base auto-embedded on first startup

# ── PRODUCTION OVERRIDES (uncomment for deployment) ─────────
# DATABASE_URL=postgresql://user:password@host:5432/creatoriq
# DEBUG=false
# FRONTEND_URL=https://yourdomain.com
